# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME=""
ZSH_DISABLE_COMPFIX=true

plugins=(git zsh-autosuggestions zsh-syntax-highlighting zsh-completions)

fpath+=${ZSH_CUSTOM:-${ZSH:-~/.oh-my-zsh}/custom}/plugins/zsh-completions/src
source $ZSH/oh-my-zsh.sh

source ~/powerlevel10k/powerlevel10k.zsh-theme

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet

{{ if eq .chezmoi.os "darwin" -}}
# === macOS specific ===

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
export CPPFLAGS="-I $(brew --prefix)/include" LDFLAGS="-L $(brew --prefix)/lib"
if which ruby >/dev/null && which gem >/dev/null; then
  PATH="$(ruby -r rubygems -e 'puts Gem.user_dir')/bin:$PATH"
fi

source /Users/aymericdeloche/.docker/init-zsh.sh || true # Added by Docker Desktop
export PATH="$HOME/.rbenv/bin:$PATH"
eval "$(rbenv init -)"
export ANDROID_HOME=$HOME/Library/Android/sdk
export PATH=$PATH:$ANDROID_HOME/emulator
export PATH=$PATH:$ANDROID_HOME/tools
export PATH=$PATH:$ANDROID_HOME/tools/bin

function idev-start-docker() {
    docker stop $(docker ps -aq)
    if [ -z "$1" ]; then
        current_dir=$(basename "$PWD")
    else
        current_dir="$1"
    fi
    /usr/local/bin/docker-compose --env-file ./.env.local -f ./docker-compose.yml -p "$current_dir" up -d
    docker-sync start
}

alias sail='sh $([ -f sail ] && echo sail || echo vendor/bin/sail)'

# Added by Windsurf
export PATH="/Users/aymericdeloche/.codeium/windsurf/bin:$PATH"

# === MLX & Hugging Face tools ===
